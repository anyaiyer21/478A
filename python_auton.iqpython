{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nbrain_inertial = Inertial()\nleft_claws = Pneumatic(Ports.PORT2)\nfront_claw_lift = Motor(Ports.PORT12, False)\nright_claws = Pneumatic(Ports.PORT5)\nback_lift_motor_a = Motor(Ports.PORT4, True)\nback_lift_motor_b = Motor(Ports.PORT3, False)\nback_lift = MotorGroup(back_lift_motor_a, back_lift_motor_b)\nbeam_handling = Pneumatic(Ports.PORT9)\nsecond_stage_flip = Motor(Ports.PORT7, True)\nleft_motor = Motor(Ports.PORT1, True)\nright_motor = Motor(Ports.PORT6, False)\nbeam_lift_dist = Distance(Ports.PORT10)\ncontroller = Controller()\n\n\n\n# generating and setting random seed\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    xaxis = brain_inertial.acceleration(XAXIS) * 1000\n    yaxis = brain_inertial.acceleration(YAXIS) * 1000\n    zaxis = brain_inertial.acceleration(ZAXIS) * 1000\n    systemTime = brain.timer.system() * 100\n    urandom.seed(int(xaxis + yaxis + zaxis + systemTime)) \n    \n# Initialize random seed \ninitializeRandomSeed()\n\n#endregion VEXcode Generated Robot Configuration\n\n# ------------------------------------------\n# \n# \tProject:      VEXcode Project\n# \tAuthor:       VEX\n# \tCreated:\n# \tDescription:  VEXcode IQ Python Project\n# \n# ------------------------------------------\n\n# Library imports\nfrom vex import *\n\n# Begin project code\n\n# left_claws solenoid\n#   cylinder 1: second_stage\n#   cylinder 2: first_stage\n\n# right_claws solenoid\n#   cylinder 1: second_stage\n#   cylinder 2: first_stage\n\n# beam_handling solenoid\n#   cylinder 1: backpacks. reverse = true, so therefore retract becomes extend and extend becomes retract\n#   cylinder 2: beam clamp. \n\n############### GLOBAL VARIABLES ###############\n\nFRONTCLAWS_OPEN = True\nPINCHY_OPEN = True\nBACKPACK_BLOCKING = True\nBEAM_GRABBED = True\n\nBREAK_FROM_TURN = 0\nTURN_SPEED = 35\n\n\n\ndef open_first_stage():\n    global FRONTCLAWS_OPEN\n    left_claws.extend(CYLINDER2)\n    right_claws.extend(CYLINDER2)\n    FRONTCLAWS_OPEN = True\n\ndef close_first_stage():\n    global FRONTCLAWS_OPEN\n    left_claws.retract(CYLINDER2)\n    right_claws.retract(CYLINDER2)\n    FRONTCLAWS_OPEN = False\n\ndef open_pinchy():\n    global PINCHY_OPEN\n    left_claws.retract(CYLINDER1)\n    right_claws.retract(CYLINDER1)\n    PINCHY_OPEN = True\n\ndef close_pinchy():\n    global PINCHY_OPEN\n    left_claws.retract(CYLINDER1)\n    right_claws.retract(CYLINDER2)\n    PINCHY_OPEN = False\n\ndef block_backpack_with_trigger():\n    global BACKPACK_BLOCKING\n    beam_handling.extend(CYLINDER1)\n    BACKPACK_BLOCKING = True\n\ndef unblock_backpack_with_trigger():\n    global BACKPACK_BLOCKING\n    beam_handling.retract(CYLINDER1)\n    BACKPACK_BLOCKING = False\n\ndef grab_beam(): # set it to \"retract\"\n    global BEAM_GRABBED\n    beam_handling.extend(CYLINDER2)\n    BEAM_GRABBED = True\n\ndef release_beam(): # set it to \"extend\"\n    global BEAM_GRABBED\n    beam_handling.retract(CYLINDER2)\n    BEAM_GRABBED = False\n\ndef reset_front_claw():\n    front_claw_lift.spin(REVERSE)\n    wait(0.5, SECONDS)\n    while (front_claw_lift.velocity(PERCENT) > 0):\n        front_claw_lift.spin(REVERSE)\n    front_claw_lift.stop()\n    wait(1, SECONDS)\n\n# resetting cascade lift with the distance sensor for when started\ndef reset_lift_using_dist():\n    release_beam()\n    unblock_backpack_with_trigger()\n    if (beam_lift_dist.object_distance(INCHES) < 1):\n        back_lift.spin_for(FORWARD, 200, DEGREES)\n    while (beam_lift_dist.object_distance(INCHES) > 1):\n        back_lift.spin(REVERSE)\n        brain.screen.print(beam_lift_dist.object_distance(INCHES))\n    back_lift.spin_for(REVERSE, 120, DEGREES)\n    grab_beam()\n    back_lift.stop()\n\n################## TURNING WITH GYRO - MYBLOCK ##################\n\ndef gyro_turn(heading):\n    global BREAK_FROM_TURN\n    global TURN_SPEED\n    if (heading > inertial.rotation()):\n        while ((heading - 1) > inertial.rotation()):\n            if BREAK_FROM_TURN == 1:\n                BREAK_FROM_TURN = 0\n                print(\"Breaking turn loop\")\n                break\n            left_motor.set_velocity(TURN_SPEED, PERCENT)\n            right_motor.set_velocity((-1 * TURN_SPEED), PERCENT)\n            left_motor.spin(FORWARD)\n            right_motor.spin(FORWARD)\n    else:\n        while ((heading + 1) < inertial.rotation()):\n            if BREAK_FROM_TURN == 1:\n                BREAK_FROM_TURN = 0\n                print(\"Breaking turn loop\")\n                break\n            left_motor.set_velocity((-1 * TURN_SPEED), PERCENT)\n            right_motor.set_velocity(TURN_SPEED, PERCENT)\n            left_motor.spin(FORWARD)\n            right_motor.spin(FORWARD)\n    left_motor.stop()\n    right_motor.stop()\n\ndef when_started():\n    right_claws.pump_off()\n    inertial.calibrate()\n    right_claws.pump_on()\n    reset_lift_using_dist()\n    open_first_stage()\n    open_pinchy()\n    release_beam()\n    block_backpack_with_trigger()\n    back_lift.set_stopping(HOLD)\n    second_stage_flip.set_velocity(200, PERCENT)\n    second_stage_flip.set_stopping(BRAKE)\n    front_claw_lift.set_velocity(200, PERCENT)\n    front_claw_lift.set_stopping(BRAKE)\n    reset_front_claw()\n    front_claw_lift.set_position(0, DEGREES)\n    second_stage_flip.set_position(0, DEGREES)\n    back_lift.set_velocity(200, PERCENT)\n    back_lift.set_position(0, DEGREES)\n    brain.play_sound(SoundType.TADA)\n","textLanguage":"python","robotConfig":[{"port":[2],"name":"left_claws","customName":true,"deviceType":"Pneumatic","deviceClass":"pneumatic","setting":{"cylinder1":"cylinder1","cylinder2":"cylinder2","cylinder1_reversed":"false","cylinder2_reversed":"false","cylinder3":"","cylinder4":""}},{"port":[12],"name":"front_claw_lift","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"}},{"port":[5],"name":"right_claws","customName":true,"deviceType":"Pneumatic","deviceClass":"pneumatic","setting":{"cylinder1":"cylinder1","cylinder2":"cylinder2","cylinder1_reversed":"false","cylinder2_reversed":"false","cylinder3":"","cylinder4":""}},{"port":[4,3],"name":"back_lift","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","motor_a_reversed":"true","motor_b_reversed":"false"}},{"port":[9],"name":"beam_handling","customName":true,"deviceType":"Pneumatic","deviceClass":"pneumatic","setting":{"cylinder1":"cylinder1","cylinder2":"cylinder2","cylinder1_reversed":"false","cylinder2_reversed":"false","cylinder3":"","cylinder4":""}},{"port":[7],"name":"second_stage_flip","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse"}},{"port":[1],"name":"left_motor","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse"}},{"port":[6],"name":"right_motor","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"}},{"port":[10],"name":"beam_lift_dist","customName":true,"deviceType":"Distance","deviceClass":"distance","setting":{}},{"port":[],"name":"controller","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","e":"","eDir":"false","f":"","fDir":"false","l3r3":"","l3r3Dir":"false","drive":"none"}}],"slot":7,"platform":"IQ","sdkVersion":"20230818.11.00.00","appVersion":"4.65.0","fileFormat":"2.0.0","targetBrainGen":"Second","v5SoundsEnabled":false,"aiVisionSettings":{"colors":[],"codes":[],"tags":true,"AIObjects":true,"AIObjectModel":[],"aiModelDropDownValue":null}}