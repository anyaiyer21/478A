{"mode":"Text","hardwareTarget":"brain","textContent":"#region VEXcode Generated Robot Configuration\nfrom vex import *\nimport urandom\nimport math\n\n# Brain should be defined by default\nbrain=Brain()\n\n# Robot configuration code\nbrain_inertial = Inertial()\n# AI Classification Competition Element IDs - Mix & Match\nclass GameElementsMixAndMatch:\n    BEAM = 0\n    BLUE_PIN = 1\n    RED_PIN = 2\n    ORANGE_PIN = 3\nleft_claws = Pneumatic(Ports.PORT2)\nfront_claw_lift = Motor(Ports.PORT12, False)\nright_claws = Pneumatic(Ports.PORT5)\nback_lift_motor_a = Motor(Ports.PORT4, True)\nback_lift_motor_b = Motor(Ports.PORT3, False)\nback_lift = MotorGroup(back_lift_motor_a, back_lift_motor_b)\nbeam_handling = Pneumatic(Ports.PORT9)\nsecond_stage_flip = Motor(Ports.PORT7, True)\nleft_motor = Motor(Ports.PORT1, False)\nright_motor = Motor(Ports.PORT6, True)\nbeam_lift_dist = Distance(Ports.PORT10)\ncontroller = Controller()\n# AI Vision Color Descriptions\n# AI Vision Code Descriptions\nai_vision_11 = AiVision(Ports.PORT11, AiVision.ALL_AIOBJS)\ntouchled_8 = Touchled(Ports.PORT8)\n\n\n\n# generating and setting random seed\ndef initializeRandomSeed():\n    wait(100, MSEC)\n    xaxis = brain_inertial.acceleration(XAXIS) * 1000\n    yaxis = brain_inertial.acceleration(YAXIS) * 1000\n    zaxis = brain_inertial.acceleration(ZAXIS) * 1000\n    systemTime = brain.timer.system() * 100\n    urandom.seed(int(xaxis + yaxis + zaxis + systemTime)) \n    \n# Initialize random seed \ninitializeRandomSeed()\n\n#endregion VEXcode Generated Robot Configuration\n\n# ------------------------------------------\n# \n# \tProject:      VEXcode Project\n# \tAuthor:       VEX\n# \tCreated:\n# \tDescription:  VEXcode IQ Python Project\n# \n# ------------------------------------------\n\n# Library imports\nfrom vex import *\n\n# Begin project code\n\n# left_claws solenoid\n#   cylinder 1: second_stage\n#   cylinder 2: first_stage\n\n# right_claws solenoid\n#   cylinder 1: second_stage\n#   cylinder 2: first_stage\n\n# beam_handling solenoid\n#   cylinder 1: backpacks. reverse = true, so therefore retract becomes extend and extend becomes retract\n#   cylinder 2: beam clamp. \n\n############### GLOBAL VARIABLES ###############\n\nFRONTCLAWS_OPEN = True\nPINCHY_OPEN = True\nBACKPACK_BLOCKING = True\nBEAM_GRABBED = True\n\nBREAK_FROM_TURN = 0\nBREAK_FROM_STRAIGHT = 0\nTURN_SPEED = 35\nSTRAIGHT_LINE_SPEED = 35\n\nabort_when_stopped_event = Event()\nflip_pinchy_and_reset_event = Event()\nload_2nd_set_event = Event()\nload_pins_on_backpack_event = Event()\n\nROUTE_1 = True\n\ndef open_front_claw():\n    global FRONTCLAWS_OPEN\n    left_claws.retract(CYLINDER2)\n    right_claws.retract(CYLINDER2)\n    FRONTCLAWS_OPEN = True\n\ndef close_front_claw():\n    global FRONTCLAWS_OPEN\n    left_claws.extend(CYLINDER2)\n    right_claws.extend(CYLINDER2)\n    FRONTCLAWS_OPEN = False\n\ndef open_pinchy():\n    global PINCHY_OPEN\n    left_claws.retract(CYLINDER1)\n    right_claws.retract(CYLINDER1)\n    PINCHY_OPEN = True\n\ndef close_pinchy():\n    global PINCHY_OPEN\n    left_claws.extend(CYLINDER1)\n    right_claws.extend(CYLINDER1)\n    PINCHY_OPEN = False\n\ndef block_backpack_with_trigger():\n    global BACKPACK_BLOCKING\n    beam_handling.retract(CYLINDER1)\n    BACKPACK_BLOCKING = True\n\ndef unblock_backpack_with_trigger():\n    global BACKPACK_BLOCKING\n    beam_handling.extend(CYLINDER1)\n    BACKPACK_BLOCKING = False\n\ndef grab_beam(): # set it to \"retract\"\n    global BEAM_GRABBED\n    beam_handling.extend(CYLINDER2)\n    BEAM_GRABBED = True\n\ndef release_beam(): # set it to \"extend\"\n    global BEAM_GRABBED\n    beam_handling.retract(CYLINDER2)\n    BEAM_GRABBED = False\n\ndef reset_front_claw():\n    front_claw_lift.spin(REVERSE)\n    wait(0.5, SECONDS)\n    while (front_claw_lift.velocity(PERCENT) > 0):\n        front_claw_lift.spin(REVERSE)\n        wait(20, MSEC)\n    front_claw_lift.stop()\n    wait(1, SECONDS)\n\n# resetting cascade lift with the distance sensor for when started\ndef reset_lift_using_dist():\n    release_beam()\n    unblock_backpack_with_trigger()\n    if (beam_lift_dist.object_distance(INCHES) < 1):\n        back_lift.spin_for(FORWARD, 200, DEGREES)\n    while (beam_lift_dist.object_distance(INCHES) > 1):\n        back_lift.spin(REVERSE)\n        brain.screen.print(beam_lift_dist.object_distance(INCHES))\n        wait(20, MSEC)\n    back_lift.spin_for(REVERSE, 120, DEGREES)\n    block_backpack_with_trigger()\n    back_lift.stop()\n\ndef drop_pins_on_beam():\n    unblock_backpack_with_trigger();\n\ndef raise_backpack_for_field_goal():\n    back_lift.spin_to_position(750,DEGREES,wait=True)\n\ndef raise_backpack_for_standoff_goal():\n    back_lift.spin_to_position(1750,DEGREES,wait=True)\n\ndef flip_pinchy_and_reset():\n    second_stage_flip.spin_to_position(-600,DEGREES)\n    wait(0.5,SECONDS)\n    open_pinchy()\n    wait(0.5,SECONDS)\n    second_stage_flip.spin_to_position(0,DEGREES,wait=False)\n\ndef transfer_pins_to_pinchy():\n    second_stage_flip.set_timeout(1, SECONDS)\n    second_stage_flip.spin_to_position(0,DEGREES)\n    second_stage_flip.set_timeout(5, SECONDS)\n    open_pinchy()\n    front_claw_lift.set_timeout(1.5,SECONDS)\n    front_claw_lift.spin_to_position(575,DEGREES)\n    close_pinchy()\n    wait(0.5,SECONDS)\n    open_front_claw()\n    front_claw_lift.spin_to_position(0,DEGREES,wait=False)\n\ndef abort_when_stopped():\n    global BREAK_FROM_STRAIGHT\n    wait(0.5,SECONDS)\n    while (True):\n        if math.fabs(left_motor.velocity(PERCENT)) <= 0:\n            BREAK_FROM_STRAIGHT = True\n            break\n        wait(20, MSEC)\n\ndef combo_transfer_pins_to_pinchy():\n    transfer_pins_to_pinchy()\n    flip_pinchy_and_reset()\n    wait(1, SECONDS)\n    # drop pins\n    unblock_backpack_with_trigger()\n    # raise the cascade without waiting\n    back_lift.spin_to_position(2000,DEGREES,wait=False)\n\n################## TURNING WITH GYRO - MYBLOCK ##################\n\ndef gyro_turn(heading):\n    global BREAK_FROM_TURN\n    global TURN_SPEED\n    if (heading > brain_inertial.rotation()):\n        while ((heading - 1) > brain_inertial.rotation()):\n            if BREAK_FROM_TURN == 1:\n                BREAK_FROM_TURN = 0\n                print(\"Breaking turn loop\")\n                break\n            left_motor.set_velocity(TURN_SPEED, PERCENT)\n            right_motor.set_velocity((-1 * TURN_SPEED), PERCENT)\n            left_motor.spin(FORWARD)\n            right_motor.spin(FORWARD)\n            wait(20, MSEC)\n    else:\n        while ((heading + 1) < brain_inertial.rotation()):\n            if BREAK_FROM_TURN == 1:\n                BREAK_FROM_TURN = 0\n                print(\"Breaking turn loop\")\n                break\n            left_motor.set_velocity((-1 * TURN_SPEED), PERCENT)\n            right_motor.set_velocity(TURN_SPEED, PERCENT)\n            left_motor.spin(FORWARD)\n            right_motor.spin(FORWARD)\n            wait(20, MSEC)\n    left_motor.stop()\n    right_motor.stop()\n\n################## DRIVING WITH GYRO - MYBLOCK ##################\n\ndef gyro_straight(distance, heading, velocity):\n    global BREAK_FROM_STRAIGHT\n    \n    distance = distance * 2 / 1.5\n    BREAK_FROM_STRAIGHT = False\n    kp = 0.5\n    left_motor.set_position(0, DEGREES)\n    right_motor.set_position(0, DEGREES)\n\n    if (velocity > 0):\n        # going forward\n        while (left_motor.position(DEGREES) < distance):\n            if BREAK_FROM_STRAIGHT == 1:\n                BREAK_FROM_STRAIGHT = 0\n                break\n            output = ((heading - brain_inertial.rotation()) * kp)\n            left_motor.set_velocity((velocity + output), PERCENT)\n            right_motor.set_velocity((velocity - output), PERCENT)\n            left_motor.spin(FORWARD)\n            right_motor.spin(FORWARD)\n            wait(20, MSEC)\n    else:\n        # going backward\n        while left_motor.position(DEGREES) > distance:\n            if BREAK_FROM_STRAIGHT == 1:\n                BREAK_FROM_STRAIGHT = 0\n                break\n            output = ((heading - brain_inertial.rotation()) * kp)\n            left_motor.set_velocity((velocity + output), PERCENT)\n            right_motor.set_velocity((velocity - output), PERCENT)\n            left_motor.spin(FORWARD)\n            right_motor.spin(FORWARD)\n            wait(20, MSEC)\n    left_motor.stop()\n    right_motor.stop()\n\n# ROUTE 1 - PART 1\ndef route1_run():\n    fast_speed = 50\n    front_claw_lift.spin_to_position(50, DEGREES,wait=False)\n    gyro_straight(400, 0, fast_speed)\n    gyro_turn(-5)\n    gyro_straight(150, -20, 35)\n    front_claw_lift.spin_to_position(0, DEGREES,wait=False)\n    wait(0.5,SECONDS)\n    close_front_claw()\n    gyro_straight(-150, -20, -55)\n    gyro_turn (-7)\n    load_pins_on_backpack_event.broadcast()\n    gyro_straight(130, 0, fast_speed)\n    gyro_turn(78)\n    heading = 90\n    wait(1, SECONDS)\n    \n    use_ai_sensor = True\n    ## AI Sensor Correction\n    if (use_ai_sensor):\n        print(\"using ai sensor\")\n        ai_objects = ai_vision_11.take_snapshot(AiVision.ALL_AIOBJS)\n        ai_object_index = 1\n        if (ai_objects[ai_object_index].centerX < 160):\n            ai_object_index = 0\n        #print(f\"ai_object_index={ai_object_index}\")\n\n        if (ai_objects[ai_object_index].centerX > 245):\n            new_heading = heading + ((ai_objects[ai_object_index].centerX - 232) / 2.5)\n            gyro_straight(330, new_heading, 35)\n            # Close front stage, right side\n            right_claws.extend(CYLINDER2)\n            gyro_straight(-170, new_heading, -35)\n            gyro_turn(brain_inertial.rotation() - ((ai_objects[ai_object_index].centerX - 232) / 14))\n        else:\n            gyro_straight(330, heading, 35)\n            right_claws.extend(CYLINDER2)\n    else:\n        gyro_straight(330, heading, 35)\n        right_claws.extend(CYLINDER2)\n\n    wait(0.25, SECONDS)\n    # code below will be to open right pinchy\n    right_claws.retract(CYLINDER1)\n    wait(0.25, SECONDS)\n    second_stage_flip.spin_to_position(-400, DEGREES, wait=False)\n    front_claw_lift.spin_to_position(50, DEGREES, wait=False)\n    abort_when_stopped_event.broadcast()\n    \n    # ram into the standoff goal\n    gyro_straight(700, 85, fast_speed)\n    # come back a bit\n    gyro_straight(-20, heading, -20)\n    # drop the pin\n    second_stage_flip.spin_to_position(-100, DEGREES, wait=True)\n    # release pinchy\n    left_claws.retract(CYLINDER1)\n    \n    gyro_straight(-30, heading, -100)\n    front_claw_lift.set_timeout(0.5, SECONDS)\n    front_claw_lift.spin_to_position(0, DEGREES,wait=True)\n    turn_speed = 40\n    gyro_turn(brain_inertial.rotation() - 15)\n    right_claws.retract(CYLINDER2)\n    gyro_straight(-500, brain_inertial.rotation(), -100)\n    second_stage_flip.spin_to_position(0, DEGREES,wait=False)\n    front_claw_lift.spin_to_position(0, DEGREES,wait=False)\n    right_claws.retract(CYLINDER1)\n    \n\n# ROUTE-2 after pin has been placed on the standoff goal\ndef route_score_beam():\n    fast_speed = 50\n    global STRAIGHT_LINE_SPEED\n    global TURN_SPEED\n    brain_inertial.set_heading(0,DEGREES)\n    brain_inertial.set_rotation(0,DEGREES)\n    abort_when_stopped_event.broadcast()\n    gyro_straight(2000, 0, 65)\n    close_front_claw()\n    gyro_straight(-265, 0, -1*STRAIGHT_LINE_SPEED)\n    gyro_turn(78)\n    wait(1, SECONDS)\n\n    use_ai_sensor = False\n    ## AI Sensor Correction\n    if (use_ai_sensor):\n        ai_objects = ai_vision_11.take_snapshot(AiVision.ALL_AIOBJS)\n        ai_object_index = 0\n        if (ai_objects[ai_object_index].centerX > 160):\n            ai_object_index = 1\n\n        if (ai_objects[ai_object_index].centerX < 130):\n            gyro_turn(brain_inertial.rotation() - ((160 - ai_objects[ai_object_index].centerX) / 12))\n\n    TURN_SPEED = 40\n    open_front_claw()\n    heading = 90\n    gyro_straight(320, heading, fast_speed)\n    close_front_claw()\n    # get the first two pins to the pinchy\n    transfer_pins_to_pinchy()\n    flip_pinchy_and_reset_event.broadcast()\n    # get the first yellow\n    gyro_straight(250, heading, 35)\n    gyro_turn(87)\n    heading = 83\n    # get second yellow\n    gyro_straight(320, heading, 35)\n    close_front_claw()\n    gyro_straight(-215, heading, -25)\n    gyro_straight(65, heading, 25)\n    front_claw_lift.spin_to_position(100,DEGREES,wait=False)\n    gyro_turn(155)\n    route_beam_cont()\n\n# Part 2 of ROUTE-2\ndef route_beam_cont():\n    global STRAIGHT_LINE_SPEED\n    global TURN_SPEED\n    heading = 180\n    abort_when_stopped_event.broadcast()\n    gyro_straight(-500, heading, -1*STRAIGHT_LINE_SPEED)\n    # gyro_straight(100, heading, 55)\n    # abort_when_stopped_event.broadcast()\n    # gyro_straight(-500, heading, -100)\n    # gyro_straight(100, heading, 55)\n    # abort_when_stopped_event.broadcast()\n    # gyro_straight(-500, heading, -100)\n    load_2nd_set_event.broadcast()\n    grab_beam()\n    # wait(0.25,SECONDS)\n    # release_beam()\n    # wait(0.25,SECONDS)\n    # grab_beam()\n    wait(0.25,SECONDS)\n    back_lift.spin_for(FORWARD,200,DEGREES,wait=False)\n    gyro_straight(150,heading,45)\n    gyro_turn(20)\n    back_lift.spin_for(REVERSE,200,DEGREES,wait=False)\n    heading = 0\n    abort_when_stopped_event.broadcast()\n    STRAIGHT_LINE_SPEED = 50\n    gyro_straight(-300,heading,-1*STRAIGHT_LINE_SPEED)\n    wait(0.5, SECONDS)\n    unblock_backpack_with_trigger()\n    # back_lift.set_timeout(9, SECONDS)\n    back_lift.spin_to_position(2000,DEGREES,wait=False)\n    wait(5, SECONDS)\n    gyro_straight(50, heading, 65)\n    gyro_straight(-50, heading, -65)\n    # wait(3, SECONDS)\n    abort_when_stopped_event.broadcast()\n    gyro_straight(-500,heading,-1*STRAIGHT_LINE_SPEED)\n    STRAIGHT_LINE_SPEED=80\n    for i in range(1):\n        left_motor.set_velocity(100,PERCENT)\n        left_motor.spin(REVERSE)\n        wait(0.5,SECONDS)\n        left_motor.stop()\n        right_motor.set_velocity(100,PERCENT)\n        right_motor.spin(REVERSE)\n        wait(0.5,SECONDS)\n        right_motor.stop()\n\n    left_motor.spin(REVERSE)\n    right_motor.spin(REVERSE)\n    back_lift.spin_to_position(1500,DEGREES,wait=True)\n    release_beam()\n    gyro_straight(200,heading,70)\n\ndef run_code():\n    brain_inertial.set_heading(0,DEGREES)\n    brain_inertial.set_rotation(0,DEGREES)\n    route1_run()\n\ndef run_code_2():\n    brain_inertial.set_heading(0,DEGREES)\n    brain_inertial.set_rotation(0,DEGREES)\n    route_score_beam()\n\ndef start_run():\n    global ROUTE_1\n    brain_inertial.set_heading(0, DEGREES)\n    brain_inertial.set_rotation(0, DEGREES)\n    if ROUTE_1:\n        touchled_8.set_color(Color.ORANGE)\n        ROUTE_1 = False\n        route1_run()\n    else:\n        touchled_8.set_color(Color.RED_VIOLET)\n        route_score_beam()\n    touchled_8.set_color(Color.GREEN)\n\ndef route_190_part_1():\n    brain_inertial.set_heading(0,DEGREES)\n    brain_inertial.set_rotation(0,DEGREES)\n    heading = 0\n    close_front_claw()\n    front_claw_lift.spin_to_position(100,DEGREES,wait=False)\n    gyro_straight(1000, heading, STRAIGHT_LINE_SPEED + 20)\n    gyro_turn(78)\n    front_claw_lift.spin_to_position(0,DEGREES,wait=False)\n    # wait(0.5, SECONDS)\n    open_front_claw()\n    # wait(1, SECONDS)\n    TURN_SPEED = 40\n    heading = 90\n    gyro_straight(320, heading, STRAIGHT_LINE_SPEED+15)\n    close_front_claw()\n    # get the first two pins to the pinchy\n    transfer_pins_to_pinchy()\n    flip_pinchy_and_reset_event.broadcast()\n    # get the first yellow\n    gyro_straight(250, heading, 35)\n    gyro_turn(87)\n    heading = 83\n    # get second yellow\n    gyro_straight(320, heading, 35)\n    close_front_claw()\n    gyro_straight(-85, heading, -25)\n    # gyro_straight(65, heading, 25)\n    front_claw_lift.spin_to_position(100,DEGREES,wait=False)\n    gyro_turn(155)\n    heading = 180\n    abort_when_stopped_event.broadcast()\n    gyro_straight(-500, heading, -1*(STRAIGHT_LINE_SPEED+10))\n    load_2nd_set_event.broadcast()\n    route_190_part_2()\n\ndef route_190_part_2():\n    global STRAIGHT_LINE_SPEED\n    heading = 180\n    brain_inertial.set_heading(180)\n    brain_inertial.set_rotation(180)\n    grab_beam() # beam is grabbed\n    gyro_straight(100, heading, STRAIGHT_LINE_SPEED)\n    gyro_turn(165)\n    heading = 155\n    gyro_straight(275, heading, STRAIGHT_LINE_SPEED)\n    close_front_claw() # grab the red pin \n    front_claw_lift.spin_to_position(50, DEGREES, wait=False)\n\n    gyro_straight(-180, heading, -1*STRAIGHT_LINE_SPEED)\n    gyro_turn(170)\n    \n    heading = 180\n    transfer_pins_to_pinchy()\n    # wait(0.25, SECONDS)\n    second_stage_flip.spin_to_position(-400, DEGREES, wait=False)\n    front_claw_lift.spin_to_position(50, DEGREES, wait=False)\n    abort_when_stopped_event.broadcast()\n    # ram into the standoff goal\n    gyro_straight(700, heading, STRAIGHT_LINE_SPEED + 20)\n    # come back a bit\n    gyro_straight(-35, heading, -1*STRAIGHT_LINE_SPEED)\n    # drop the pin\n    second_stage_flip.spin_to_position(-100, DEGREES, wait=True)\n    # release pinchy\n    open_pinchy()\n    gyro_straight(-150, heading, -1*STRAIGHT_LINE_SPEED)\n    gyro_turn(20)\n\n    heading = 10\n    # unblock_backpack_with_trigger()\n    # back_lift.spin_to_position(2000,DEGREES,wait=False)\n    # wait(5, SECONDS)\n    # gyro_straight(50, heading, 65)\n    # gyro_straight(-50, heading, -65)\n    # wait(3, SECONDS)\n    abort_when_stopped_event.broadcast()\n    gyro_straight(-500,heading,-1*STRAIGHT_LINE_SPEED)\n    STRAIGHT_LINE_SPEED=80\n    for i in range(1):\n        left_motor.set_velocity(100,PERCENT)\n        left_motor.spin(REVERSE)\n        wait(0.25,SECONDS)\n        left_motor.stop()\n        right_motor.set_velocity(100,PERCENT)\n        right_motor.spin(REVERSE)\n        wait(0.25,SECONDS)\n        right_motor.stop()\n\n    left_motor.spin(REVERSE)\n    right_motor.spin(REVERSE)\n    back_lift.spin_to_position(1500,DEGREES,wait=True)\n    release_beam()\n    gyro_straight(200,heading,70)\n\ndef when_started():\n    right_claws.pump_off()\n\n    # Calibrate the brain inertial\n    brain_inertial.calibrate()\n    while brain_inertial.is_calibrating():\n        brain.screen.clear_screen()\n        brain.screen.set_cursor(1, 1)\n        brain.screen.print(\"Inertial Sensor\")\n        brain.screen.next_row()\n        brain.screen.print(\"Calibrating\")\n        wait(50, MSEC)\n    brain.screen.clear_screen()\n    brain.screen.set_cursor(1, 1)\n    brain.screen.print(\"Done!\")\n\n    right_claws.pump_on()\n    reset_lift_using_dist()\n    open_front_claw()\n    open_pinchy()\n    release_beam()\n    block_backpack_with_trigger()\n    back_lift.set_stopping(HOLD)\n    second_stage_flip.set_velocity(200, PERCENT)\n    second_stage_flip.set_stopping(BRAKE)\n    front_claw_lift.set_velocity(200, PERCENT)\n    front_claw_lift.set_stopping(BRAKE)\n    reset_front_claw()\n    front_claw_lift.set_position(0, DEGREES)\n    second_stage_flip.set_position(0, DEGREES)\n    back_lift.set_velocity(200, PERCENT)\n    back_lift.set_position(0, DEGREES)\n\n    # ---------- BINDING FUNCTIONS -----------\n    abort_when_stopped_event(abort_when_stopped)\n    flip_pinchy_and_reset_event(flip_pinchy_and_reset)\n    load_2nd_set_event(combo_transfer_pins_to_pinchy)\n    load_pins_on_backpack_event(transfer_pins_to_pinchy)\n\n    wait(1, SECONDS)\n\n    brain.play_sound(SoundType.TADA)\n    controller.buttonEUp.pressed(run_code)\n    controller.buttonEDown.pressed(run_code_2)\n    controller.buttonFUp.pressed(route_190_part_1)\n    controller.buttonFDown.pressed(route_190_part_2)\n    touchled_8.pressed(route_190_part_1)\n\n    touchled_8.set_color(Color.RED)\n\nwhen_started()","textLanguage":"python","robotConfig":[{"port":[2],"name":"left_claws","customName":true,"deviceType":"Pneumatic","deviceClass":"pneumatic","setting":{"cylinder1":"cylinder1","cylinder2":"cylinder2","cylinder1_reversed":"false","cylinder2_reversed":"false","cylinder3":"","cylinder4":""},"triportSourcePort":22},{"port":[12],"name":"front_claw_lift","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"},"triportSourcePort":22},{"port":[5],"name":"right_claws","customName":true,"deviceType":"Pneumatic","deviceClass":"pneumatic","setting":{"cylinder1":"cylinder1","cylinder2":"cylinder2","cylinder1_reversed":"false","cylinder2_reversed":"false","cylinder3":"","cylinder4":""},"triportSourcePort":22},{"port":[4,3],"name":"back_lift","customName":true,"deviceType":"MotorGroup","deviceClass":"motor_group","setting":{"fwd":"forward","rev":"reverse","motor_a_reversed":"true","motor_b_reversed":"false"},"triportSourcePort":22},{"port":[9],"name":"beam_handling","customName":true,"deviceType":"Pneumatic","deviceClass":"pneumatic","setting":{"cylinder1":"cylinder1","cylinder2":"cylinder2","cylinder1_reversed":"false","cylinder2_reversed":"false","cylinder3":"","cylinder4":""},"triportSourcePort":22},{"port":[7],"name":"second_stage_flip","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse"},"triportSourcePort":22},{"port":[1],"name":"left_motor","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"false","fwd":"forward","rev":"reverse"},"triportSourcePort":22},{"port":[6],"name":"right_motor","customName":true,"deviceType":"Motor","deviceClass":"motor","setting":{"reversed":"true","fwd":"forward","rev":"reverse"},"triportSourcePort":22},{"port":[10],"name":"beam_lift_dist","customName":true,"deviceType":"Distance","deviceClass":"distance","setting":{},"triportSourcePort":22},{"port":[],"name":"controller","customName":false,"deviceType":"Controller","deviceClass":"controller","setting":{"left":"","leftDir":"false","right":"","rightDir":"false","e":""